# WHM Configuration
WHM_ENABLED=true
WHM_URL=
WHM_HOST=servolam.olamulticom.com.br
WHM_PORT=2087
WHM_USERNAME=root
WHM_API_TOKEN=
WHM_TIMEOUT_MS=10000
WHM_REJECT_UNAUTHORIZED=true
WHM_IP_FAMILY=4
WHM_SYNC_INTERVAL_MS=3600000
WHM_EXCLUDE_SUSPENDED=true
WHM_EXCLUDE_SUBDOMAINS=false
WHM_EXCLUDE_ADDON_DOMAINS=false
WHM_ONLY_MAIN_DOMAINS=false
WHM_EMAIL_STATS_ENABLED=true
WHM_EMAIL_STATS_CONCURRENCY=4
WHM_RDAP_ENABLED=true
WHM_RDAP_CONCURRENCY=3
WHM_SERVER_PROBE_ENABLED=true
WHM_SERVER_PROBE_TIMEOUT_MS=12000
WHM_IP_ENRICHMENT_ENABLED=true
WHM_IP_ENRICHMENT_TIMEOUT_MS=8000
WHM_SERVER_PLAN=VPS Linux
WHM_SERVER_SYSTEM=No disponible

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TIMEOUT_MS=10000

# RDAP Configuration
RDAP_ENABLED=true
RDAP_BASE_URL=rdap.registro.br
RDAP_TIMEOUT_MS=7000
RDAP_ONLY_BR=true

# Monitor Configuration
MONITOR_TIMEOUT_MS=10000
MONITOR_USER_AGENT=Website-Monitor/2.0
MONITOR_MAX_RETRIES=2
MONITOR_PARALLEL_LIMIT=10
MONITOR_HISTORY_LIMIT=100
MONITOR_CONCURRENCY=10

# Other
IPINFO_TOKEN=
LOG_LEVEL=info
NODE_ENV=development
