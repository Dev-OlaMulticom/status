{
  "name": "status-olamulticom",
  "version": "1.0.0",
  "private": true,
  "description": "Website and WHM status monitor",
  "main": "monitor.ts",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "npm run monitor && npm run frontend:dev",
    "monitor": "ts-node monitor.ts",
    "whm:test": "ts-node test-whm.ts",
    "typecheck": "tsc --noEmit",
    "validate:syntax": "npm run typecheck",
    "test:full": "bash FULL_TEST.sh",
    "cache:clear": "ts-node cache-tools.ts all",
    "cache:clear:whm": "ts-node cache-tools.ts whm",
    "cache:clear:cloudflare": "ts-node cache-tools.ts cloudflare",
    "cache:clear:rdap": "ts-node cache-tools.ts rdap",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
