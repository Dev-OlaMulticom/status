{
  "name": "status-olamulticom",
  "version": "2.0.0",
  "private": true,
  "description": "Website and WHM status monitor — Clean Architecture refactor",
  "main": "src/monitor.ts",
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "dotenvx run -- ts-node --project tsconfig.json src/monitor.ts",
    "dev:frontend": "pnpm --filter status-olamulticom-frontend run dev",
    "monitor": "dotenvx run -- ts-node --project tsconfig.json src/monitor.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "cache:clear": "ts-node --project tsconfig.json src/cache-tools.ts all",
    "cache:clear:whm": "ts-node --project tsconfig.json src/cache-tools.ts whm",
    "cache:clear:cloudflare": "ts-node --project tsconfig.json src/cache-tools.ts cloudflare",
    "cache:clear:rdap": "ts-node --project tsconfig.json src/cache-tools.ts rdap",
    "cache:clear:dns": "ts-node --project tsconfig.json src/cache-tools.ts dns",
    "cache:clear:ssl": "ts-node --project tsconfig.json src/cache-tools.ts ssl",
    "cache:clear:whois": "ts-node --project tsconfig.json src/cache-tools.ts whois",
    "check:cloudflare": "dotenvx run -- ts-node --project tsconfig.json src/check-cloudflare.ts",
    "frontend:dev": "pnpm --filter status-olamulticom-frontend run dev",
    "frontend:build": "pnpm --filter status-olamulticom-frontend run build",
    "frontend:preview": "pnpm --filter status-olamulticom-frontend run preview"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "@keyv/sqlite": "^3.6.7",
    "@mem0/vercel-ai-provider": "^3.0.0",
    "cloudflare": "^4.5.0",
    "date-fns": "^3.6.0",
    "dns2": "^2.4.0",
    "dotenv": "^17.4.2",
    "got": "^12.6.1",
    "keyv": "^5.6.0",
    "p-limit": "^5.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "ssl-checker": "^2.0.10",
    "whoiser": "^1.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@dotenvx/dotenvx": "^2.0.0",
    "@types/node": "^24.13.2",
    "concurrently": "^10.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
